# Nexus Exchange MCP server — environment variables.
# Copy to .env and fill in. NEVER commit real secrets.

# Exchange API base URL (the public /api/exchange proxy path).
# Defaults to https://exchange.nexus.xyz/api/exchange when unset — matches
# the code default in src/config.ts and the README. To trade as a specific
# account, point this at a direct indexer gateway that verifies client HMAC
# (see the README "Authentication" section).
NEXUS_EXCHANGE_API_URL=https://exchange.nexus.xyz/api/exchange

# HMAC API credentials. Only required for account reads and trading
# (get_balance, get_positions, get_open_orders, place_order, cancel_order).
# Market-data tools work without these.
NEXUS_EXCHANGE_API_KEY=
NEXUS_EXCHANGE_API_SECRET=
