# Nexus Exchange MCP server — environment variables.
# Copy to .env and fill in. NEVER commit real secrets.

# Exchange API base URL — the direct-service HOST ROOT (no path).
# Defaults to https://exchange.nexus.xyz when unset. The server serves most
# tools from the direct `/api/v1` surface at this root (ENG-4740); the few
# routes without a v1 route yet (demo reads, market specs, get_order by id,
# withdrawals, adl-history, ws-tokens) fall back to the legacy `/api/exchange`
# gateway, which stays live dual-stack.
#
# A legacy value that still includes the `/api/exchange` suffix is accepted and
# normalized (the suffix is stripped before building /api/v1 URLs). To trade as
# a specific account, point this at a direct indexer gateway that verifies
# client HMAC (see the README "Authentication" section), e.g. http://localhost:9090
NEXUS_EXCHANGE_API_URL=https://exchange.nexus.xyz

# HMAC API credentials. Only required for account reads and trading
# (get_balance, get_positions, get_open_orders, place_order, cancel_order).
# Market-data tools work without these.
NEXUS_EXCHANGE_API_KEY=
NEXUS_EXCHANGE_API_SECRET=
