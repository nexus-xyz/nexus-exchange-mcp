# Nexus Exchange MCP server — environment variables.
# Copy to .env and fill in. NEVER commit real secrets.

# Exchange API host root (serves the direct-indexer /api/v1 surface).
# Defaults to https://exchange.nexus.xyz when unset — matches the code default
# in src/config.ts and the README. Legacy-only routes append /api/exchange
# automatically; a value that still ends in /api/exchange is accepted and
# normalized. To trade as a specific account, point this at a direct indexer
# gateway that verifies client HMAC (see the README "Authentication" section).
NEXUS_EXCHANGE_API_URL=https://exchange.nexus.xyz

# HMAC API credentials. Only required for account reads and trading
# (get_balance, get_positions, get_open_orders, place_order, cancel_order).
# Market-data tools work without these.
#
# For the stdio server these are the account it trades as. For the hosted
# Streamable HTTP server (npm run start:http) they are only a fallback — each
# HTTP session normally supplies its own credential via request headers
# (X-Nexus-Api-Key / X-Nexus-Api-Secret); see the README "Hosted HTTP server".
NEXUS_EXCHANGE_API_KEY=
NEXUS_EXCHANGE_API_SECRET=

# Session token (Bearer) from the `login` tool / POST /auth/login. Only needed
# for the API-key management tools (list_api_keys, create_api_key,
# delete_api_key), which authenticate with a session token rather than HMAC.
NEXUS_EXCHANGE_SESSION_TOKEN=

# Admin tier tools (list_tiers, set_tier, delete_tier) are operator-only and
# OFF by default. They use the gateway's admin secret and mutate other
# accounts' fee tiers — never enable on an untrusted agent surface. To opt in,
# set ENABLE_ADMIN_TOOLS=1 and provide the admin secret.
NEXUS_EXCHANGE_ENABLE_ADMIN_TOOLS=
NEXUS_EXCHANGE_ADMIN_SECRET=

# Hosted Streamable HTTP server (src/http-index.ts) listen config. Only used by
# `npm run start:http`. The MCP endpoint is served at MCP_HTTP_PATH and a
# liveness probe at /healthz.
MCP_HTTP_PORT=8080
MCP_HTTP_PATH=/mcp
