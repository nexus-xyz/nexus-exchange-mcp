{
  "name": "@nexus-xyz/exchange-mcp",
  "version": "0.1.0",
  "description": "MCP server for the Nexus Exchange API \u2014 lets an AI agent read market data and place trades.",
  "license": "(MIT OR Apache-2.0)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nexus-xyz/nexus-exchange-mcp.git"
  },
  "homepage": "https://github.com/nexus-xyz/nexus-exchange-mcp#readme",
  "type": "module",
  "bin": {
    "nexus-exchange-mcp": "dist/index.js",
    "nexus-exchange-mcp-http": "dist/http-index.js"
  },
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "start:http": "node dist/http-index.js",
    "dev": "tsc -p tsconfig.json --watch",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --test --import tsx test/*.test.ts",
    "test:coverage": "c8 --reporter=text-summary --reporter=text --reporter=lcov --reporter=json-summary --src src node --test --import tsx test/*.test.ts",
    "smoke": "node --import tsx scripts/smoke.ts",
    "prepublishOnly": "npm run build && npm test"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.1.0",
    "c8": "^11.0.0",
    "eslint": "^10.6.0",
    "globals": "^17.7.0",
    "prettier": "^3.9.4",
    "tsx": "^4.23.0",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.63.0"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "nexus",
    "exchange",
    "trading",
    "agent"
  ],
  "files": [
    "dist",
    "README.md",
    "LICENSE-MIT",
    "LICENSE-APACHE"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
